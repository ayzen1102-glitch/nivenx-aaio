# ─────────────────────────────────────────
#  NivenX — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────

# Required — Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Required — Your bot's application/client ID
DISCORD_CLIENT_ID=

# Optional — MongoDB connection string (for moderation, tickets, giveaways etc.)
MONGODB_URL=mongodb://localhost:27017/nivenx

# Optional — Guild ID to deploy slash commands to instantly during development
GUILD_ID=

# Optional — Gemini AI API key (for YouTube Verifier feature)
GEMINI_API_KEY=

# Optional — PostgreSQL URL (for Verifier feature)
DATABASE_URL=

# Optional — Set to "true" if running in production with HTTPS
LIVE=false
