# ── Discord ────────────────────────────────────────────────────────────────────
# Bot token from discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=your_discord_bot_token_here

# Application ID from discord.com/developers/applications → General Information
CLIENT_ID=your_discord_client_id_here

# ── Google Gemini AI ───────────────────────────────────────────────────────────
# API key from aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── PostgreSQL Database ────────────────────────────────────────────────────────
# Connection string for your PostgreSQL database
# e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=your_postgres_connection_string_here
